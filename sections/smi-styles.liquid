{%- liquid
  assign _prefix = ''
  if section.location == 'template'
    assign _prefix = '.shopify-section'
  endif
-%}
<style>
    {% if block_color %}
    {% endif %}
  {% if request.design_mode %}
    section.smi-styles{
        position: fixed;
        top: 30%;
    }
  {% endif %}
  {% for block in section.blocks %}
      {% case block.type %}
          {% when 'color' %}
{%-liquid
    assign color_class1 = ', body .smi-color-scheme_'
    assign color_class2 = 'body .smi-section'
    if section.location == 'template'
      assign color_class1 = ', body ' | append: _prefix | append: ' .smi-color-scheme_'
      assign color_class2 = 'body ' | append: _prefix | append: '.smi-section'
    endif 
-%}
{% for i in (1..10) -%}
    {% assign scheme_classes = scheme_classes | append: color_class1 | append: i %}
    {% if i == 1 -%}
        body .smi-section,
    {%- endif %}
    {%-liquid
        assign key_bg = 'background_color' | append: i
        assign key_gradient = 'background_gradient_color' | append: i
        assign key_text = 'text_color' | append: i
        assign key_subtext = 'subtext_color' | append: i
        assign key_solid_bg = 'solid_background_button_color' | append: i
        assign key_solid_label = 'solid_button_label_color' | append: i
        assign key_outline = 'outline_button_color' | append: i
        assign key_shadow = 'shadow_color' | append: i
		assign key_heading = 'heading_color' | append: i
		assign key_link = 'link_color' | append: i
		assign key_hover_link = 'hover_link_color' | append: i
		assign key_solid_bg_hover = 'solid_background_button_hover_color' | append: i
		assign key_solid_label_hover = 'solid_button_label_hover_color' | append: i
		assign key_outline_hover = 'outline_button_hover_color' | append: i
		assign key_input_background = 'input_background_color' | append: i
		assign key_input_color = 'input_color' | append: i
		assign key_input_border = 'input_border_color' | append: i
		assign key_input_border_hover = 'input_border_hover_color' | append: i
    -%}
    body {{ _prefix }} .smi-color-scheme_{{ i }} {
    --color-background: {{ block.settings[key_bg].red }},{{ block.settings[key_bg].green }},{{ block.settings[key_bg].blue }};
    --color-background-alpha: {{ block.settings[key_bg].alpha }};
    {% if block.settings[key_gradient] != empty %}
        --gradient-background: {{ block.settings[key_gradient] }};
    {% else %}
        --gradient-background: {{ block.settings[key_bg] }};
    {% endif %}
    --color-foreground: {{ block.settings[key_text].red }},{{ block.settings[key_text].green }},{{ block.settings[key_text].blue }};
    --color-subtext: {{ block.settings[key_subtext].red }},{{ block.settings[key_subtext].green }},{{ block.settings[key_subtext].blue }};
    --color-shadow: {{ block.settings[key_shadow].red }},{{ block.settings[key_shadow].green }},{{ block.settings[key_shadow].blue }};
    --color-button: {{ block.settings[key_solid_bg].red }},{{ block.settings[key_solid_bg].green }},{{ block.settings[key_solid_bg].blue }};
    --color-button-text: {{ block.settings[key_solid_label].red }},{{ block.settings[key_solid_label].green }},{{ block.settings[key_solid_label].blue }};
    --color-secondary-button: {{ block.settings[key_bg].red }},{{ block.settings[key_bg].green }},{{ block.settings[key_bg].blue }};
    --color-secondary-button-text: {{ block.settings[key_outline].red }},{{ block.settings[key_outline].green }},{{ block.settings[key_outline].blue }};
    --color-link: {{ block.settings[key_outline].red }},{{ block.settings[key_outline].green }},{{ block.settings[key_outline].blue }};
    --color-badge-border: {{ block.settings[key_text].red }},{{ block.settings[key_text].green }},{{ block.settings[key_text].blue }};
	{% if block.settings[key_heading] != 'rgba(0,0,0,0)' %}
		--color-heading: {{ block.settings[key_heading].red }},{{ block.settings[key_heading].green }},{{ block.settings[key_heading].blue }};
	{% endif %}
	{% comment %} not changing heading {% endcomment %}
	{% if block.settings[key_link] != 'rgba(0,0,0,0)' and block.settings[key_link] != blank %}
		--color-text-link: {{ block.settings[key_link].red }},{{ block.settings[key_link].green }},{{ block.settings[key_link].blue }};
	{% else %}
		--color-text-link: {{ block.settings[key_text].red }},{{ block.settings[key_text].green }},{{ block.settings[key_text].blue }};
	{% endif %}
	{% if block.settings[key_hover_link] != 'rgba(0,0,0,0)' and block.settings[key_hover_link] != blank %}
		--color-hover-link: {{ block.settings[key_hover_link].red }},{{ block.settings[key_hover_link].green }},{{ block.settings[key_hover_link].blue }};
	{% elsif block.settings[key_link] != 'rgba(0,0,0,0)' and block.settings[key_link] != blank %}
		--color-hover-link: {{ block.settings[key_link].red }},{{ block.settings[key_link].green }},{{ block.settings[key_link].blue }};
	{% else %}
		--color-hover-link: {{ block.settings[key_text].red }},{{ block.settings[key_text].green }},{{ block.settings[key_text].blue }};
	{% endif %}
	{% if block.settings[key_solid_bg_hover] != 'rgba(0,0,0,0)' and block.settings[key_solid_bg_hover] != blank %}
		--color-button-hover: {{ block.settings[key_solid_bg_hover].red }},{{ block.settings[key_solid_bg_hover].green }},{{ block.settings[key_solid_bg_hover].blue }};
	{% else %}
		--color-button-hover: {{ block.settings[key_solid_bg].red }},{{ block.settings[key_solid_bg].green }},{{ block.settings[key_solid_bg].blue }};
	{% endif %}
	{% if block.settings[key_solid_label_hover] != 'rgba(0,0,0,0)' and block.settings[key_solid_label_hover] != blank %}
		--color-button-hover-text: {{ block.settings[key_solid_label_hover].red }},{{ block.settings[key_solid_label_hover].green }},{{ block.settings[key_solid_label_hover].blue }};
	{% else %}
		--color-button-hover-text: {{ block.settings[key_solid_label].red }},{{ block.settings[key_solid_label].green }},{{ block.settings[key_solid_label].blue }};
	{% endif %}
	{% if block.settings[key_outline_hover] != 'rgba(0,0,0,0)' and block.settings[key_outline_hover] != blank %}
		--color-button-hover-border: {{ block.settings[key_outline_hover].red }},{{ block.settings[key_outline_hover].green }},{{ block.settings[key_outline_hover].blue }};
	{% else %}
		--color-button-hover-border: {{ block.settings[key_outline].red }},{{ block.settings[key_outline].green }},{{ block.settings[key_outline].blue }};
	{% endif %}
	{% if block.settings[key_input_background] != 'rgba(0,0,0,0)' and block.settings[key_input_background] != blank %}
		--color-input-background: {{ block.settings[key_input_background].red }},{{ block.settings[key_input_background].green }},{{ block.settings[key_input_background].blue }};
	{% endif %}
	{% if block.settings[key_input_color] != 'rgba(0,0,0,0)' and block.settings[key_input_color] != blank %}
		--color-input-color: {{ block.settings[key_input_color].red }},{{ block.settings[key_input_color].green }},{{ block.settings[key_input_color].blue }};
	{% else %}
		--color-input-color: {{ block.settings[key_text].red }},{{ block.settings[key_text].green }},{{ block.settings[key_text].blue }};
	{% endif %}
	{% comment %} not changing color-input-border, color-input-border-hover {% endcomment %}
	{% if block.settings[key_input_border] != 'rgba(0,0,0,0)' and block.settings[key_input_border] != blank %}
		--color-input-border: {{ block.settings[key_input_border].red }},{{ block.settings[key_input_border].green }},{{ block.settings[key_input_border].blue }};
	{% else %}
		--color-input-border: {{ block.settings[key_text].red }},{{ block.settings[key_text].green }},{{ block.settings[key_text].blue }};
	{% endif %}
	{% if block.settings[key_input_border_hover] != 'rgba(0,0,0,0)' and block.settings[key_input_border_hover] != blank %}
		--color-input-border-hover: {{ block.settings[key_input_border_hover].red }},{{ block.settings[key_input_border_hover].green }},{{ block.settings[key_input_border_hover].blue }};
	{% else %}
		--color-input-border-hover: {{ block.settings[key_text].red }},{{ block.settings[key_text].green }},{{ block.settings[key_text].blue }};
	{% endif %}
    }
{% endfor %}
{{ scheme_classes | prepend: color_class2 }} {
    color: rgba(var(--color-foreground), 1);
    background-color: rgba(var(--color-background), var(--color-background-alpha, 1));
}
          {% when 'typography' %}
              {% liquid
  assign bs = block.settings
  assign typoAdvance = section.blocks | where: 'type', 'typography_advance' | first
  if typoAdvance
    assign tas = typoAdvance.settings
    assign bodyFontWeight = ''
    assign headingFontWeight = ''
    assign bodyFontWeight = bodyFontWeight | append: tas.fontweight_badge | append: ','
    if bs.button_font == 'heading'
      assign headingFontWeight = headingFontWeight | append: tas.fontweight_button | append: ','
    else
      assign bodyFontWeight = bodyFontWeight | append: tas.fontweight_button | append: ','
    endif
    if bs.price_font == 'heading'
      assign headingFontWeight = headingFontWeight | append: tas.fontweight_price | append: ','
    else
      assign bodyFontWeight = bodyFontWeight | append: tas.fontweight_price | append: ','
    endif
    if bs.menu_font == 'heading'
      assign headingFontWeight = headingFontWeight | append: tas.fontweight_menu | append: ','
    else
      assign bodyFontWeight = bodyFontWeight | append: tas.fontweight_menu | append: ','
    endif
    if bs.subheading_font == 'heading'
      assign headingFontWeight = headingFontWeight | append: tas.fontweight_subheading | append: ','
    else
      assign bodyFontWeight = bodyFontWeight | append: tas.fontweight_subheading | append: ','
    endif
    assign bodyFontWeight = bodyFontWeight | split: ',' | compact | uniq
    assign headingFontWeight = headingFontWeight | split: ',' | compact | uniq
  endif
  if block.settings.overwrite_font
    for i in bodyFontWeight
      echo bs.type_body_font | font_modify: 'weight', i | font_face: font_display: 'swap'
    endfor
    for i in headingFontWeight
      echo bs.type_header_font | font_modify: 'weight', i | font_face: font_display: 'swap'
    endfor
	for i in accentFontWeight
      echo bs.type_accent_font | font_modify: 'weight', i | font_face: font_display: 'swap'
    endfor
    echo block.settings.type_body_font | font_face: font_display: 'swap'
    echo block.settings.type_header_font | font_face: font_display: 'swap'
    echo block.settings.type_accent_font | font_face: font_display: 'swap'
  endif
%}
{% capture preload_font -%}
  {%- if block.settings.overwrite_font -%}
    {%- unless block.settings.smi_type_body_font.system? -%}
      {% comment %}theme-check-disable AssetPreload{% endcomment %}
      <link rel="preload" as="font" href="{{ block.settings.type_body_font | font_url }}" type="font/woff2" crossorigin>
      {%- for i in bodyFontWeight %}
        <link rel="preload" as="font" href="{{ block.settings.type_body_font | font_modify: 'weight', i | font_url }}" type="font/woff2" crossorigin>
      {% endfor -%}
      {% comment %}theme-check-enable AssetPreload{% endcomment %}
    {%- endunless -%}
    {%- unless block.settings.smi_type_header_font.system? -%}
      {% comment %}theme-check-disable AssetPreload{% endcomment %}
      <link rel="preload" as="font" href="{{ block.settings.type_header_font | font_url }}" type="font/woff2" crossorigin>
      {%- for i in headingFontWeight %}
        <link rel="preload" as="font" href="{{ block.settings.type_header_font | font_modify: 'weight', i | font_url }}" type="font/woff2" crossorigin>
      {% endfor -%}
      {% comment %}theme-check-enable AssetPreload{% endcomment %}
    {%- endunless -%}
	{%- unless block.settings.smi_type_accent_font.system? -%}
	{% comment %}theme-check-disable AssetPreload{% endcomment %}
	<link rel="preload" as="font" href="{{ block.settings.type_accent_font | font_url }}" type="font/woff2" crossorigin>
	{%- for i in headingFontWeight %}
	  <link rel="preload" as="font" href="{{ block.settings.type_accent_font | font_modify: 'weight', i | font_url }}" type="font/woff2" crossorigin>
	{% endfor -%}
	{% comment %}theme-check-enable AssetPreload{% endcomment %}
  {%- endunless -%}
  {%- endif -%}
{%- endcapture %}
body {{ _prefix }}.smi-section {
{% if block.settings.overwrite_font %}
  --font-body-family: {{ block.settings.type_body_font.family }},{{ block.settings.type_body_font.fallback_families }};
  --font-body-style: {{ block.settings.type_body_font.style }};
  --font-body-weight: {{ block.settings.type_body_font.weight }};
  --font-body-weight-bold: {{ block.settings.type_body_font.weight | plus: 300 | at_most: 1000 }};
  --font-heading-family: {{ block.settings.type_header_font.family }}, {{- block.settings.type_header_font.fallback_families -}};
  --font-heading-style: {{ block.settings.type_header_font.style }};
  --font-heading-weight: {{ block.settings.type_header_font.weight }};
  --font-accent-family: {{ block.settings.type_accent_font.family }}, {{- block.settings.type_accent_font.fallback_families -}};
  --font-accent-style: {{ block.settings.type_accent_font.style }};
  --font-accent-weight: {{ block.settings.type_accent_font.weight }};
  font-family: var(--font-body-family);
  font-style: var(--font-body-style); font-weight: var(--font-body-weight);
{% endif %}
--font-heading-scale: {{ block.settings.heading_scale | divided_by: 100.0 }};
{% if block.settings.heading_scale > 120 %}
  --font-heading-scale-max: 1.2;
{% else %}
  --font-heading-scale-max: {{ block.settings.heading_scale | divided_by: 100.0 }};
{% endif %}
--heading-line-height-scale: {{ block.settings.heading_line_height_scale | divided_by: 100.0 }};
--heading-letter-spacing-scale: {{ block.settings.heading_letter_spacing_scale }}px;
--heading-text-case:
{%- if block.settings.heading_text_case != 'original' -%}
  {{- block.settings.heading_text_case -}}
{%- else -%}
  {{- 'unset' -}}
{%- endif -%};
--font-body-scale: {{ block.settings.body_scale | divided_by: 100.0 }};
--body-line-height-scale: {{ block.settings.body_line_height_scale | divided_by: 100.0 }};
--body-letter-spacing-scale: {{ block.settings.body_letter_spacing_scale }}px;
--body-line-height: calc((1 + .8 / {{- block.settings.body_scale | divided_by: 100.0 -}}) * {{ block.settings.body_line_height_scale | divided_by: 100.0 }});
--button-font-family: var({{ '--font-' | append: block.settings.button_font | append: '-family' }});
--button-text-case: {{ block.settings.button_text_case }}; --price-font-family: var({{- '--font-' | append: block.settings.price_font | append: '-family' -}});
--menu-font-family: var({{ '--font-' | append: block.settings.menu_font | append: '-family' }});
--subheading-font-family: var({{ '--font-' | append: block.settings.subheading_font | append: '-family' }});
}
{% if block.settings.overwrite_font %}
  body {{ _prefix }}.smi-section h1, body {{ _prefix }}.smi-section h2, body {{ _prefix }}.smi-section h3, body
  {{ _prefix }}.smi-section h4, body {{ _prefix }}.smi-section h5, body {{ _prefix }}.smi-section h6, body
  {{ _prefix }}.smi-section .smi-h1, body {{ _prefix }}.smi-section .smi-h2, body {{ _prefix }}.smi-section .smi-h3,
  body {{ _prefix }}.smi-section .smi-h4, body {{ _prefix }}.smi-section .smi-h5, body {{ _prefix }}.smi-section
  .smi-h6{ font-family: var(--font-heading-family); font-style: var(--font-heading-style); font-weight:
  var(--font-heading-weight); }
  body {{ _prefix }} .smi-text-xs, body {{ _prefix }} .smi-text-sm, body {{ _prefix }} .smi-text-md, body
  {{ _prefix }} .smi-text-lg { font-family: var(--font-body-family); }
  body {{ _prefix }} .smi-text-menu { font-family: var(--menu-font-family); }
  body {{ _prefix }} .smi-text-button { font-family: var(--button-font-family); }
  body {{ _prefix }} .smi-text-button-purchase { font-family: var(--button-font-family); }
  body {{ _prefix }} .smi-text-sub { font-family: var(--subheading-font-family); }
  body {{ _prefix }} .smi-text-price-md, body {{ _prefix }} .smi-text-price-lg, body {{ _prefix }} .smi-text-price-xl {
  font-family: var(--price-font-family); }
  body {{ _prefix }} .smi-text-accent,   body {{ _prefix }} .smi-highlighted-text em { font-family: var(--font-accent-family); font-style: var(--font-accent-style); font-weight:
  var(--font-accent-weight); }
{% endif %}
{% comment %} Text accent mới cho hightlight {% endcomment %}
{% comment %} .smi-text-accent {% endcomment %}
          {% when 'typography_advance' %}
    body {{ _prefix }}.smi-section {
        --h1-font-size: {{ block.settings.fontsize_h1 }};
        --h2-font-size: {{ block.settings.fontsize_h2 }};
        --h3-font-size: {{ block.settings.fontsize_h3 }};
        --h4-font-size: {{ block.settings.fontsize_h4 }};
        --h5-font-size: {{ block.settings.fontsize_h5 }};
        --h6-font-size: {{ block.settings.fontsize_h6 }};
        --h1-font-size-xs: {{ block.settings.fontsize_xs_h1 }};
        --h2-font-size-xs: {{ block.settings.fontsize_xs_h2 }};
        --h3-font-size-xs: {{ block.settings.fontsize_xs_h3 }};
        --h4-font-size-xs: {{ block.settings.fontsize_xs_h4 }};
        --h5-font-size-xs: {{ block.settings.fontsize_xs_h5 }};
        --h6-font-size-xs: {{ block.settings.fontsize_xs_h6 }};
        --text-xs-font-size: {{ block.settings.text_fontsize_xs }};
        --text-sm-font-size: {{ block.settings.text_fontsize_sm }};
        --text-md-font-size: {{ block.settings.text_fontsize_md }};
        --text-lg-font-size: {{ block.settings.text_fontsize_lg }};
		--text-xs-font-size-mb: {{ block.settings.text_fontsize_xs_mb }};
		--text-sm-font-size-mb: {{ block.settings.text_fontsize_sm_mb }};
		--text-md-font-size-mb: {{ block.settings.text_fontsize_md_mb }};
		--text-lg-font-size-mb: {{ block.settings.text_fontsize_lg_mb }};
        --button-font-size: {{ block.settings.fontsize_button }};
        --button-font-weight: {{ block.settings.fontweight_button }};
        --subheading-font-size: {{ block.settings.fontsize_subheading }};
        --subheading-font-size-sm: {{ block.settings.fontsize_subheading_sm }};
		--subheading-font-size-mb: {{ block.settings.fontsize_subheading_mb }};
		--subheading-font-size-sm-mb: {{ block.settings.fontsize_subheading_sm_mb }};
        --subheading-font-weight: {{ block.settings.fontweight_subheading }};
        --badge-font-size: {{ block.settings.fontsize_badge }};
        --badge-font-weight: {{ block.settings.fontweight_badge }};
        --menu-font-size: {{ block.settings.fontsize_menu }};
        --menu-font-weight: {{ block.settings.fontweight_menu }};
		--input-font-size: {{ block.settings.fontsize_input }};
		--input-font-weight: {{ block.settings.fontweight_input }};
        --price-font-size-xl: {{ block.settings.fontsize_price_xl }};
        --price-font-size-lg: {{ block.settings.fontsize_price_lg }};
        --price-font-size-md: {{ block.settings.fontsize_price_md }};
        --price-font-weight: {{ block.settings.fontweight_price }};
        --button-letter-spacing-scale: {{ block.settings.button_letter_spacing_scale }}px;
        --subheading-letter-spacing-scale: {{ block.settings.subheading_letter_spacing_scale }}px;
        --badge-letter-spacing-scale: {{ block.settings.badge_letter_spacing_scale }}px;
        --menu-letter-spacing-scale: {{ block.settings.menu_letter_spacing_scale }}px;
		--input-letter-spacing-scale: {{ block.settings.input_letter_spacing_scale }}px;
        --price-letter-spacing-scale: {{ block.settings.price_letter_spacing_scale }}px;
    }
          {% when 'layout' %}
              body {{ _prefix }}.smi-section {
    --page-width: {{ block.settings.page_width }}px;
	--fullwidth-padding: {{ block.settings.fullwidth_padding }}px;
    --page-width-margin: {% if block.settings.page_width == '1600' %}2{% else %}0{% endif %}rem;
    --spacing-sections-desktop: {{ block.settings.spacing_sections }}px;
    --spacing-sections-mobile: {% if block.settings.spacing_sections < 24 %}{{ block.settings.spacing_sections }}{% else %}{{ block.settings.spacing_sections | times: 0.7 | round | at_least: 20 }}{% endif %}px;
    --spacing-elements: {{ block.settings.spacing_elements_mobile | divided_by: 100.0 }};
    --grid-desktop-vertical-spacing: {{ block.settings.spacing_grid_vertical }}px;
    --grid-desktop-horizontal-spacing: {{ block.settings.spacing_grid_horizontal }}px;
    --grid-mobile-vertical-spacing: {{ block.settings.spacing_grid_vertical_mobile }}px;
    --grid-mobile-horizontal-spacing: {{ block.settings.spacing_grid_horizontal_mobile }}px;
}
@media screen and (min-width: 992px){
    body {{ _prefix }}.smi-section{
        --spacing-elements: {{ block.settings.spacing_elements | divided_by: 100.0 }};
    }
}
          {% when 'buttons' %}
              body {{ _prefix }}.smi-section {
    --buttons-scale: {{ block.settings.buttons_scale | divided_by: 100.0 }};
    --buttons-radius: {{ block.settings.buttons_radius }}px;
    --buttons-radius-outset: {% if block.settings.buttons_radius > 0 %}{{ block.settings.buttons_radius | plus: block.settings.buttons_border_thickness }}{% else %}0{% endif %}px;
    --buttons-border-width: {% if block.settings.buttons_border_opacity > 0 %}{{ block.settings.buttons_border_thickness }}{% else %}0{% endif %}px;
    --buttons-border-opacity: {{ block.settings.buttons_border_opacity | divided_by: 100.0 }};
    --buttons-shadow-opacity: {{ block.settings.buttons_shadow_opacity | divided_by: 100.0 }};
    --buttons-shadow-visible: {% if block.settings.buttons_shadow_opacity > 0 and block.settings.buttons_shadow != '0,0,0' %}1{% else %}0{% endif %};
	{% if block.settings.custom_button_size %}
		--buttons-padding-horizontal: {{ block.settings.button_padding_horizontal_desktop }}px;
		--buttons-padding-vertical: {{ block.settings.button_padding_vertical_desktop }}px;
		@media screen and (max-width: 767.98px) {
			--buttons-padding-horizontal: {{ block.settings.button_padding_horizontal_mobile }}px;
			--buttons-padding-vertical: {{ block.settings.button_padding_vertical_mobile }}px;
		}
	{% endif %}
	{% if block.settings.custom_button_shadow %}
		--buttons-shadow-horizontal-offset: {{ block.settings.button_shadow_position_x }}px;
		--buttons-shadow-vertical-offset: {{ block.settings.button_shadow_position_y }}px;
		--buttons-shadow-blur-radius: {{ block.settings.button_shadow_blur }}px;
	{% else %}
		{% assign smi_buttons_shadow = block.settings.buttons_shadow | split: "," %}
		--buttons-shadow-horizontal-offset: {{ smi_buttons_shadow[0] }}px;
		--buttons-shadow-vertical-offset: {{ smi_buttons_shadow[1] }}px;
		--buttons-shadow-blur-radius: {{ smi_buttons_shadow[2] }}px;
	{% endif %}
    --buttons-border-offset: {% if block.settings.buttons_radius > 0 or block.settings.buttons_shadow_opacity > 0 %}0.3{% else %}0{% endif %}px;
}
          {% when 'variants' %}
              body {{ _prefix }}.smi-section {
    {% if block.settings.variant_pills_border_thickness == 0 %}
    --variant-pills-border-width-min: 1px;
    --border-product-button-20: 0;
    --variant-pills-border-width-20-min: 1px;
    {% else %}
    --variant-pills-border-width-min: {{ block.settings.variant_pills_border_thickness }}px;
    --border-product-button-20: 0.2;
